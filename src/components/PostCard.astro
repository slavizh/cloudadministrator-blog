---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../utils/paths";
import { resolveAssetUrl } from "../utils/assets";
import { calculateReadTime, formatDate, getTagColor } from "../utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const published = formatDate(post.data.pubDate);
const readTime = calculateReadTime(post.body);
---

<a href={withBase(`${post.slug}/`)} class="card-link" data-tags={JSON.stringify(post.data.tags.map(t => t.toLowerCase()))}>
  <article class="card">
    <div class="card__image">
      <img src={resolveAssetUrl(post.data.heroImage)} alt={post.data.title} loading="lazy" />
      <span class="card__badge">Blog</span>
    </div>
    <div class="card__body">
      <h3 class="card__title">{post.data.title}</h3>
      {post.data.excerpt && (
        <p class="card__excerpt">{post.data.excerpt}</p>
      )}
      {post.data.tags.length > 0 && (
        <div class="card__tags">
          {post.data.tags.slice(0, 3).map((tag) => (
            <span class={`tag-pill tag-pill--${getTagColor(tag)}`}>{tag}</span>
          ))}
        </div>
      )}
      <div class="card__meta">
        <time>{published}</time>
        <span>&middot;</span>
        <span>{readTime} min read</span>
      </div>
    </div>
  </article>
</a>

<style>
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .card-link:hover {
    color: inherit;
  }
</style>

