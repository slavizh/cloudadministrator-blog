---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="share-post">
  <h3 class="share-post__heading">Share this post</h3>
  <div class="share-post__actions">
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-post__btn"
      aria-label="Share on LinkedIn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"></path></svg>
    </a>
    <a
      href={`https://bsky.app/intent/compose?text=${encodedTitle}%20${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-post__btn"
      aria-label="Share on Bluesky"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.63 3.625 3.502 6.301 3.082-4.876.807-6.406 3.291-3.601 5.726C6.259 21.57 9.12 22 11.999 20.086 14.88 22 17.742 21.57 20.676 19.055c2.805-2.435 1.275-4.92-3.601-5.726 2.676.42 5.516-.452 6.3-3.082.247-.828.625-5.79.625-6.479 0-.688-.139-1.86-.902-2.203-.659-.3-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8"></path></svg>
    </a>
    <a
      href={`https://x.com/intent/post?text=${encodedTitle}&url=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-post__btn"
      aria-label="Share on X"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768m2.46-2.46l6.772-6.772"></path></svg>
    </a>
    <a
      href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-post__btn"
      aria-label="Share on Telegram"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9L2 9l20-7z"></path></svg>
    </a>
    <a
      href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
      target="_blank"
      rel="noopener noreferrer"
      class="share-post__btn"
      aria-label="Share on Facebook"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
    </a>
    <button
      class="share-post__copy"
      aria-label="Copy link"
      data-url={url}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
      <span>Copy Link</span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.share-post__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-url');
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const span = btn.querySelector('span');
        if (span) {
          const original = span.textContent;
          span.textContent = 'Copied!';
          setTimeout(() => { span.textContent = original; }, 2000);
        }
      } catch {
        // fallback
      }
    });
  });
</script>

<style>
  .share-post {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    margin-top: 2.5rem;
  }

  .share-post__heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-muted-foreground);
    margin: 0;
  }

  .share-post__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-post__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    color: var(--color-muted-foreground);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .share-post__btn:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  .share-post__copy {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  .share-post__copy:hover {
    background: var(--color-accent);
    color: var(--color-primary);
  }

  .share-post__copy span {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
