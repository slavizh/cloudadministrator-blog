<style>
  .site-footer {
    padding: 3rem 0 2rem;
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) { .site-footer { margin-top: 5rem; } }
  @media (min-width: 1024px) { .site-footer { margin-top: 6rem; } }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-brand__name {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-muted-foreground);
    opacity: 0.6;
  }

  .footer-copyright {
    font-size: 0.75rem;
    color: var(--color-muted-foreground);
    opacity: 0.6;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .footer-icon {
    color: var(--color-muted-foreground);
    transition: color 0.2s;
  }

  .footer-icon:hover {
    color: var(--color-primary);
  }

  .footer-credits {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-muted-foreground);
    opacity: 0.6;
    line-height: 1.6;
  }

  .footer-credits a {
    color: var(--color-muted-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-credits a:hover {
    color: var(--color-primary);
  }

  .footer-disclaimer {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--color-muted-foreground);
    opacity: 0.5;
    line-height: 1.6;
    max-width: 48rem;
    margin-left: auto;
    margin-right: auto;
  }
</style>
