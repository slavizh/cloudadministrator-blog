---
import { withBase } from "../utils/paths";

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;
const navItems = [
  { href: withBase(""), key: "/", label: "Home" },
  { href: withBase("about/"), key: "/about/", label: "About" },
  { href: withBase("archive/"), key: "/archive/", label: "Archive" },
  { href: withBase("topics/"), key: "/topics/", label: "Topics" },
  { href: withBase("search/"), key: "/search/", label: "Search" }
];

function isActive(itemKey: string, path: string): boolean {
  if (itemKey === "/") return path === "/" || path === "";
  return path.startsWith(itemKey);
}
