</BaseLayout>

<style>
  .about-portrait {
    float: left;
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 50%;
    margin: 0 1.5rem 1rem 0;
    border: 3px solid var(--color-border);
  }

  .about-mvp {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }

  .social-links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--color-foreground);
    font-weight: 500;
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: var(--color-primary);
  }

  .social-links svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .social-links a:hover svg {
    opacity: 1;
  }
</style>
