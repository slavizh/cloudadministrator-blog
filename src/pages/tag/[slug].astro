---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPostsByTaxonomy, getTaxonomyEntries, sortPosts } from "../../utils/blog";
import { withBase } from "../../utils/paths";

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection("blog", ({ data }) => !data.draft));
  const tags = getTaxonomyEntries(posts, "tags");

  return tags.map((tag) => ({
    params: { slug: tag.slug },
    props: {
      tagName: tag.name,
      posts: getPostsByTaxonomy(posts, "tags", tag.name)
    }
  }));
}

const { tagName, posts } = Astro.props;
---

<BaseLayout
  title={`Tag: ${tagName}`}
  description={`Browse posts tagged ${tagName}.`}
  canonicalUrl={Astro.url.toString()}
>
  <div class="page-header">
    <p class="breadcrumbs">
      <a href={withBase("topics/")}>Topics</a>
      <span>/</span>
      <span>{tagName}</span>
    </p>
    <p class="eyebrow">Tag</p>
    <h1>{tagName}</h1>
    <p>{posts.length} posts with this tag.</p>
  </div>

  <section class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
